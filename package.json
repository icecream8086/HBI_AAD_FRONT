{
  "name": "hbi-aad-front",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "lint": "vue-cli-service lint",
    "docs:openapi": "openapi-generator-cli generate -i http://localhost:3000/api/openapi.json -g typescript-axios -o src/api/generated --type-mappings integer=int",
    "docs:openapi:local": "openapi-generator-cli generate -i openapi.json -g typescript-axios -o src/api/generated --type-mappings integer=int"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.0",
    "element-plus": "^2.7.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-plugin-typescript": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "^3.4.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.0",
    "typescript": "~5.4.0",
    "vitest": "^1.6.0"
  }
}
